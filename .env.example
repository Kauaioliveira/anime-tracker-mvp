# Copy to `.env` and adjust. `.env` is not committed (see .gitignore).
#
# Security: never put private API keys or secrets in VITE_* variables — they are
# embedded in the browser bundle. Real secrets belong on a server / backend only.

# Jikan API v4 base URL (https only; no trailing slash)
VITE_JIKAN_BASE_URL=https://api.jikan.moe/v4
